<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Advertising ID (GAID) is OPT-IN and OFF by default, so the AD_ID permission
      is intentionally NOT declared here — declaring it would force every host into
      Google Play Data Safety AD_ID disclosure. Apps that enable IDFA/GAID
      attribution add it to their own manifest:

        <uses-permission android:name="com.google.android.gms.permission.AD_ID" />

      See docs/GOOGLE_PLAY_DATA_SAFETY.md → "Advertising ID (GAID) — Opt-in".
    -->

    <application>
        <!-- Full-screen host for the imperative interstitial API. -->
        <activity
            android:name="ad.simula.ad.sdk.ads.SimulaInterstitialActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode"
            android:theme="@style/Theme.Simula.Interstitial" />

        <!-- Full-screen host for the imperative rewarded minigame API. -->
        <activity
            android:name="ad.simula.ad.sdk.ads.SimulaRewardedActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode"
            android:theme="@style/Theme.Simula.Interstitial" />
    </application>
</manifest>
